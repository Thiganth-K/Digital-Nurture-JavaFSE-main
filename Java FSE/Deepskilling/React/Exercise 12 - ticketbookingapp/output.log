  isLoggedIn = false → GuestPage shown (flight list table)
  isLoggedIn = true  → UserPage shown  (booking section)

  {isLoggedIn ? <UserPage /> : <GuestPage />}

  Login button  → handleLogin()  → setState({ isLoggedIn: true  })
  Logout button → handleLogout() → setState({ isLoggedIn: false })

